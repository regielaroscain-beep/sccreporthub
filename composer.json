{
    "name": "scc/reporthub",
    "type": "project",
    "description": "SCC ReportHub – A Web-Based Campus Facility Status Report and Monitoring System",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "cloudinary/cloudinary_php": "^2.0",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "nunomaduro/collision",
                "spatie/laravel-ignition"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "ignore": {
                "PKSA-m5cs-t1y6-qpcs": "Ignoring for production build",
                "PKSA-3r5d-mb8f-1qw9": "Ignoring for production build",
                "PKSA-mdq4-51ck-6kdq": "Ignoring for production build",
                "PKSA-8qx3-n5y5-vvnd": "Ignoring for production build",
                "PKSA-w7xr-vk7n-rstm": "Ignoring for production build"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
